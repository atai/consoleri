{
  "name": "@consoleri/desktop",
  "version": "0.2.0",
  "description": "Consoleri desktop — SSH, shell, RDP, VNC host manager",
  "main": "./out/main/index.js",
  "author": "consoleri",
  "homepage": "https://github.com/consoleri/consoleri",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "pnpm run typecheck:node && pnpm run typecheck:web",
    "start": "electron-vite preview",
    "build:app": "electron-vite build",
    "dev:watch": "electron-vite dev",
    "dev": "pnpm run build:app && pnpm run dev:watch",
    "build": "pnpm run typecheck && pnpm run build:app",
    "build:unpack": "pnpm run build && electron-builder --dir",
    "build:win": "pnpm run build && electron-builder --win",
    "build:mac": "pnpm run build && electron-builder --mac",
    "build:linux": "pnpm run build && electron-builder --linux",
    "package": "pnpm run build:win",
    "test": "vitest run --coverage && vitest run --config vitest.main.config.ts --coverage",
    "test:main": "vitest run --config vitest.main.config.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@consoleri/core": "workspace:*",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@novnc/novnc": "^1.7.0",
    "@xterm/addon-canvas": "^0.7.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-webgl": "^0.18.0",
    "@xterm/xterm": "^5.5.0",
    "@xyflow/react": "^12.11.0",
    "d3-force": "^3.0.0",
    "dagre": "^0.8.5",
    "ironrdp-wasm": "^1.1.0",
    "lucide-react": "^1.18.0",
    "nanoid": "^5.1.5",
    "node-pty": "^1.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-mosaic-component": "^7.0.0-beta0",
    "ssh2": "^1.16.0",
    "ws": "^8.18.2",
    "zod": "^3.25.67",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron/rebuild": "^3.7.2",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/react": "^16.3.2",
    "@types/d3-force": "^3.0.10",
    "@types/dagre": "^0.7.54",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/ssh2": "^1.15.5",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "3.2.6",
    "electron": "42.2.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "jsdom": "^26.1.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vitest": "^3.2.4"
  }
}
