{
  "name": "consoleri",
  "version": "0.4.1",
  "private": true,
  "description": "Consoleri — remote host console manager",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "node scripts/pnpm.mjs --filter @consoleri/desktop build",
    "package": "node scripts/pnpm.mjs --filter @consoleri/desktop build:win",
    "lint": "node scripts/pnpm.mjs --filter @consoleri/desktop lint",
    "typecheck": "node scripts/pnpm.mjs --filter @consoleri/desktop typecheck",
    "test": "node scripts/pnpm.mjs --filter @consoleri/core test && node scripts/pnpm.mjs --filter @consoleri/desktop test",
    "install:deps": "node scripts/pnpm.mjs install",
    "rebuild-native": "node scripts/rebuild-native.mjs",
    "install:electron": "node node_modules/electron/install.js",
    "postinstall": "node scripts/postinstall.mjs",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "version:set": "node scripts/bump-version.mjs",
    "release": "bash scripts/release.sh"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "pnpm": "10.12.1"
  }
}
